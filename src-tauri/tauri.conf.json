{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toolbox",
  "version": "0.1.0",
  "identifier": "com.toolbox.app",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "cd ../web && npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Toolbox — 工具百宝箱",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
