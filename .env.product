# Toolbox 生产环境变量
# 复制为 .env 并填写实际值后部署

# ========== 必填 ==========

# 管理员令牌 — 保护 LLM 配置写操作（POST/DELETE /settings/llm）
# 生成随机值：openssl rand -hex 32
TOOLBOX_ADMIN_TOKEN=

# ========== 可选覆盖 ==========

# 文件转换接口每 IP 限流（slowapi 语法），空串关闭
TOOLBOX_RATE_LIMIT=20/minute

# 上传大小上限（MB），超出返回 413
TOOLBOX_MAX_UPLOAD_MB=100

# Swagger / ReDoc UI（生产保持 0）
TOOLBOX_DEBUG=0

# LLM 配置与模型缓存持久化目录（Docker 挂载卷路径，保持默认即可）
TOOLBOX_DATA_DIR=/data
HF_HOME=/data/huggingface
DOCLING_CACHE=/data/docling
